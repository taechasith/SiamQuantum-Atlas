SIAMQUANTUM_ENV=development
SIAMQUANTUM_DATABASE_URL=sqlite:///data/processed/siamquantum_atlas.db
SIAMQUANTUM_ANTHROPIC_API_KEY=sk-ant-...
SIAMQUANTUM_CLAUDE_MODEL=claude-3-5-sonnet-latest
SIAMQUANTUM_YOUTUBE_API_KEY=AIza...
SIAMQUANTUM_GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
SIAMQUANTUM_VIEWER_PORT=8765
SIAMQUANTUM_DEPLOYMENT_MODE=local
SIAMQUANTUM_DATABASE_READ_ONLY=false
MAXMIND_LICENSE_KEY=your_license_key_here

# Supabase env vars are required for auth, profile management, and submitted data.
# Use the real values only in your local .env / .env.local files. Never commit private keys.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_SECRET_KEY=your_server_only_secret_key_here

# Prefect orchestration (optional — only needed when using `siamquantum orchestration deploy`)
# Leave blank to use the ephemeral local runner (`siamquantum orchestration serve`).
PREFECT_API_URL=http://127.0.0.1:4200/api
# PREFECT_API_KEY=your_prefect_cloud_key_here   # only for Prefect Cloud
PREFECT_WORK_POOL=local-process
